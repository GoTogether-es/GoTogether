{
  "version": 2,
  "outputDirectory": "apps/web/.next",
  "functions": {
    "backend-api/index.ts": {
      "includeFiles": "apps/api/prisma/schema.prisma",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend-api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "apps/web/$1"
    }
  ]
}
